---
---
<!-- AR Visualizer Button -->
<button id="ar-open-btn" class="mt-4 w-full flex items-center justify-center gap-3 border border-brand-gold/60 text-brand-gold font-medium py-3 rounded-lg hover:bg-brand-gold hover:text-brand-dark transition-all cursor-pointer bg-transparent text-base">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
  </svg>
  <span id="ar-btn-label" data-i18n="arButton">Ver en tu pared</span>
</button>

<!-- AR Fullscreen Overlay (hidden by default) -->
<div id="ar-overlay" class="fixed inset-0 z-50 bg-black" style="display:none;">
  <!-- Close button -->
  <button id="ar-close-btn" class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-black/60 text-white border border-white/30 cursor-pointer">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Camera feed -->
  <video id="ar-video" autoplay playsinline class="absolute inset-0 w-full h-full object-cover"></video>

  <!-- Frame overlay (centered rectangle) -->
  <div id="ar-frame-rect" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 border-4 border-brand-gold pointer-events-none" style="width:200px;height:250px;">
    <div class="absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap text-brand-gold text-sm font-medium bg-black/60 px-2 py-0.5 rounded" id="ar-dimensions"></div>
  </div>

  <!-- Instruction text -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 bg-black/60 text-white text-sm px-4 py-2 rounded-lg" id="ar-instruction" data-i18n="arInstruction">
    Apunta a la pared para visualizar el tamaño
  </div>

  <!-- Error message (hidden) -->
  <div id="ar-error" class="absolute inset-0 flex items-center justify-center text-white text-lg" style="display:none;">
    <span id="ar-error-text" data-i18n="arCameraError">Cámara no disponible</span>
  </div>
</div>

<script>
  const arOpenBtn = document.getElementById('ar-open-btn')!;
  const arOverlay = document.getElementById('ar-overlay')!;
  const arCloseBtn = document.getElementById('ar-close-btn')!;
  const arVideo = document.getElementById('ar-video') as HTMLVideoElement;
  const arFrameRect = document.getElementById('ar-frame-rect')!;
  const arDimensions = document.getElementById('ar-dimensions')!;
  const arError = document.getElementById('ar-error')!;

  // Scale: roughly 20cm per 100px (adjustable reference)
  const CM_PER_PX = 20 / 100;

  let stream: MediaStream | null = null;

  function updateFrameSize() {
    const w = (window as any).__frameWidth || 40;
    const h = (window as any).__frameHeight || 50;
    const pxW = w / CM_PER_PX;
    const pxH = h / CM_PER_PX;
    // Cap to 80% of viewport
    const maxW = window.innerWidth * 0.8;
    const maxH = window.innerHeight * 0.7;
    const scale = Math.min(1, maxW / pxW, maxH / pxH);
    arFrameRect.style.width = `${Math.round(pxW * scale)}px`;
    arFrameRect.style.height = `${Math.round(pxH * scale)}px`;
    arDimensions.textContent = `${w} x ${h} cm`;
  }

  async function openAR() {
    arOverlay.style.display = '';
    updateFrameSize();
    try {
      stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'environment' }
      });
      arVideo.srcObject = stream;
    } catch {
      arVideo.style.display = 'none';
      arError.style.display = '';
    }
  }

  function closeAR() {
    arOverlay.style.display = 'none';
    if (stream) {
      stream.getTracks().forEach(t => t.stop());
      stream = null;
    }
    arVideo.srcObject = null;
    arVideo.style.display = '';
    arError.style.display = 'none';
  }

  arOpenBtn.addEventListener('click', openAR);
  arCloseBtn.addEventListener('click', closeAR);

  // Update frame rectangle live if dimensions change while AR is open
  const origSetWidth = Object.getOwnPropertyDescriptor(window, '__frameWidth');
  let _fw = 40, _fh = 50;
  Object.defineProperty(window, '__frameWidth', {
    get() { return _fw; },
    set(v) { _fw = v; if (arOverlay.style.display !== 'none') updateFrameSize(); },
    configurable: true
  });
  Object.defineProperty(window, '__frameHeight', {
    get() { return _fh; },
    set(v) { _fh = v; if (arOverlay.style.display !== 'none') updateFrameSize(); },
    configurable: true
  });
</script>
