---
import { FRAME_TYPES, GLASS_TYPES, MIN_SIDE_CM, MAX_SIDE_CM } from '../config/prices';
---
<section id="calculator" class="py-24 md:py-32 px-4 bg-brand-dark">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-4 text-brand-ivory" data-i18n="calculatorTitle">Calculadora de precios</h2>
    <div class="w-16 h-px bg-brand-gold mx-auto mb-16"></div>

    <form id="calc-form" class="space-y-6 bg-brand-dark-alt p-8 md:p-10 rounded-xl border border-brand-gold/30">
      <!-- Width -->
      <div>
        <label for="calc-width" class="block text-xs font-medium uppercase tracking-[0.15em] mb-2 text-brand-ivory-muted" data-i18n="widthLabel">Ancho (cm)</label>
        <input
          type="number"
          id="calc-width"
          name="width"
          min={MIN_SIDE_CM}
          max={MAX_SIDE_CM}
          value="40"
          required
          class="w-full bg-brand-dark border border-brand-gold/30 rounded-lg px-4 py-3 text-brand-ivory focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none transition-colors"
        />
      </div>

      <!-- Height -->
      <div>
        <label for="calc-height" class="block text-xs font-medium uppercase tracking-[0.15em] mb-2 text-brand-ivory-muted" data-i18n="heightLabel">Alto (cm)</label>
        <input
          type="number"
          id="calc-height"
          name="height"
          min={MIN_SIDE_CM}
          max={MAX_SIDE_CM}
          value="50"
          required
          class="w-full bg-brand-dark border border-brand-gold/30 rounded-lg px-4 py-3 text-brand-ivory focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none transition-colors"
        />
      </div>

      <!-- Frame type -->
      <div>
        <label for="calc-frame" class="block text-xs font-medium uppercase tracking-[0.15em] mb-2 text-brand-ivory-muted" data-i18n="frameTypeLabel">Tipo de marco</label>
        <select
          id="calc-frame"
          name="frame"
          class="w-full bg-brand-dark border border-brand-gold/30 rounded-lg px-4 py-3 text-brand-ivory focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none transition-colors cursor-pointer"
        >
          {FRAME_TYPES.map((f) => (
            <option value={f.id} data-price={f.pricePerMeter} data-label-es={f.labelES} data-label-de={f.labelDE} data-label-en={f.labelEN}>
              {f.labelES} — €{f.pricePerMeter.toFixed(2)}/m
            </option>
          ))}
        </select>
      </div>

      <!-- With glass -->
      <div class="flex items-center gap-3">
        <input type="checkbox" id="calc-glass" name="withGlass" checked class="calc-checkbox" />
        <label for="calc-glass" class="text-xs font-medium uppercase tracking-[0.15em] text-brand-ivory-muted cursor-pointer" data-i18n="withGlassLabel">¿Con cristal?</label>
      </div>

      <!-- Glass type -->
      <div id="glass-type-wrapper">
        <label for="calc-glass-type" class="block text-xs font-medium uppercase tracking-[0.15em] mb-2 text-brand-ivory-muted" data-i18n="glassTypeLabel">Tipo de cristal</label>
        <select
          id="calc-glass-type"
          name="glassType"
          class="w-full bg-brand-dark border border-brand-gold/30 rounded-lg px-4 py-3 text-brand-ivory focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none transition-colors cursor-pointer"
        >
          {GLASS_TYPES.map((g) => (
            <option value={g.id} data-price={g.pricePerM2} data-label-es={g.labelES} data-label-de={g.labelDE} data-label-en={g.labelEN}>
              {g.labelES} — €{g.pricePerM2.toFixed(2)}/m²
            </option>
          ))}
        </select>
      </div>

      <!-- With backing -->
      <div class="flex items-center gap-3">
        <input type="checkbox" id="calc-backing" name="withBacking" checked class="calc-checkbox" />
        <label for="calc-backing" class="text-xs font-medium uppercase tracking-[0.15em] text-brand-ivory-muted cursor-pointer" data-i18n="withBackingLabel">¿Con trasera de cartón?</label>
      </div>

      <!-- Live price result (always visible) -->
      <div id="calc-results" class="mt-2 pt-6 border-t border-brand-gold/20 space-y-3">
        <div class="flex justify-between text-brand-ivory-muted">
          <span data-i18n="frameCostLabel">Coste del marco</span>
          <span id="result-frame" class="font-medium text-brand-ivory">€0.00</span>
        </div>
        <div id="result-glass-row" class="flex justify-between text-brand-ivory-muted">
          <span data-i18n="glassCostLabel">Coste del cristal</span>
          <span id="result-glass" class="font-medium text-brand-ivory">€0.00</span>
        </div>
        <hr class="border-brand-gold/20" />
        <div class="flex justify-between items-baseline">
          <span class="text-sm uppercase tracking-[0.15em] text-brand-ivory-muted" data-i18n="totalLabel">Total estimado</span>
          <span id="result-total" class="font-heading text-3xl md:text-4xl font-bold text-brand-gold">€0.00</span>
        </div>
      </div>

      <!-- WhatsApp button -->
      <a
        id="whatsapp-btn"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 flex items-center justify-center gap-3 bg-brand-whatsapp text-white font-medium py-3.5 rounded-lg hover:brightness-110 transition-all text-lg"
        aria-label="Order via WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span data-i18n="orderWhatsApp">Pedir por WhatsApp</span>
      </a>
    </form>
  </div>
</section>

<script>
  import { translations } from '../i18n/translations';
  import type { Lang } from '../i18n/translations';

  function getLang(): Lang {
    const html = document.documentElement.lang;
    if (html === 'de' || html === 'en') return html;
    return 'es';
  }

  const form = document.getElementById('calc-form') as HTMLFormElement;
  const glassCheck = document.getElementById('calc-glass') as HTMLInputElement;
  const backingCheck = document.getElementById('calc-backing') as HTMLInputElement;
  const glassWrapper = document.getElementById('glass-type-wrapper') as HTMLDivElement;

  function calculate() {
    const lang = getLang();
    const t = translations[lang];

    const width = parseFloat((document.getElementById('calc-width') as HTMLInputElement).value) || 0;
    const height = parseFloat((document.getElementById('calc-height') as HTMLInputElement).value) || 0;
    const frameSelect = document.getElementById('calc-frame') as HTMLSelectElement;
    const glassSelect = document.getElementById('calc-glass-type') as HTMLSelectElement;
    const withGlass = glassCheck.checked;

    const frameOption = frameSelect.selectedOptions[0];
    const framePricePerMeter = parseFloat(frameOption.dataset.price!);
    const actualFrameLabel = frameOption.getAttribute(`data-label-${lang}`) || frameOption.textContent || '';

    const frameMeters = 2 * (width + height) / 100;
    const frameCost = frameMeters * framePricePerMeter;
    const areaM2 = (width * height) / 10000;

    let glassCost = 0;
    let glassLabel: string = t.noGlass;
    if (withGlass) {
      const glassOption = glassSelect.selectedOptions[0];
      const glassPricePerM2 = parseFloat(glassOption.dataset.price!);
      glassCost = areaM2 * glassPricePerM2;
      glassLabel = glassOption.getAttribute(`data-label-${lang}`) || glassOption.textContent || '';
    }

    const total = Math.round((frameCost + glassCost) * 100) / 100;

    document.getElementById('result-frame')!.textContent = `€${frameCost.toFixed(2)}`;
    document.getElementById('result-glass')!.textContent = `€${glassCost.toFixed(2)}`;
    document.getElementById('result-total')!.textContent = `€${total.toFixed(2)}`;

    const glassRow = document.getElementById('result-glass-row') as HTMLDivElement;
    glassRow.style.display = withGlass ? '' : 'none';

    // WhatsApp link
    const msg = t.whatsappMessage
      .replace('{width}', String(width))
      .replace('{height}', String(height))
      .replace('{frameLabel}', actualFrameLabel)
      .replace('{glassLabel}', glassLabel)
      .replace('{total}', total.toFixed(2));

    const waUrl = `https://wa.me/34647020269?text=${encodeURIComponent(msg)}`;
    (document.getElementById('whatsapp-btn') as HTMLAnchorElement).href = waUrl;
  }

  // Live calculation on any input change
  const inputs = ['calc-width', 'calc-height', 'calc-frame', 'calc-glass-type', 'calc-glass', 'calc-backing'];
  inputs.forEach(id => {
    const el = document.getElementById(id);
    el?.addEventListener('input', calculate);
    el?.addEventListener('change', calculate);
  });

  glassCheck.addEventListener('change', () => {
    glassWrapper.style.display = glassCheck.checked ? '' : 'none';
    backingCheck.disabled = !glassCheck.checked;
    if (!glassCheck.checked) backingCheck.checked = false;
    calculate();
  });

  // Prevent form submit refresh, just recalculate
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    calculate();
  });

  // Initial calculation on page load
  calculate();
</script>
