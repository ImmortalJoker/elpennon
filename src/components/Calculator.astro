---
import { FRAME_TYPES, GLASS_TYPES, MIN_SIDE_CM, MAX_SIDE_CM } from '../config/prices';
---
<section id="calculator" class="py-16 px-4">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-10 text-amber-900" data-i18n="calculatorTitle">Calculadora de precios</h2>

    <form id="calc-form" class="space-y-6 bg-white p-8 rounded-xl shadow-lg border border-gray-100">
      <!-- Width -->
      <div>
        <label for="calc-width" class="block font-semibold mb-1 text-gray-700" data-i18n="widthLabel">Ancho (cm)</label>
        <input
          type="number"
          id="calc-width"
          name="width"
          min={MIN_SIDE_CM}
          max={MAX_SIDE_CM}
          value="40"
          required
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none"
        />
      </div>

      <!-- Height -->
      <div>
        <label for="calc-height" class="block font-semibold mb-1 text-gray-700" data-i18n="heightLabel">Alto (cm)</label>
        <input
          type="number"
          id="calc-height"
          name="height"
          min={MIN_SIDE_CM}
          max={MAX_SIDE_CM}
          value="50"
          required
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none"
        />
      </div>

      <!-- Frame type -->
      <div>
        <label for="calc-frame" class="block font-semibold mb-1 text-gray-700" data-i18n="frameTypeLabel">Tipo de marco</label>
        <select
          id="calc-frame"
          name="frame"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none"
        >
          {FRAME_TYPES.map((f) => (
            <option value={f.id} data-price={f.pricePerMeter} data-label-es={f.labelES} data-label-de={f.labelDE} data-label-en={f.labelEN}>
              {f.labelES} — €{f.pricePerMeter.toFixed(2)}/m
            </option>
          ))}
        </select>
      </div>

      <!-- With glass -->
      <div class="flex items-center gap-3">
        <input type="checkbox" id="calc-glass" name="withGlass" checked class="w-5 h-5 text-amber-600 rounded focus:ring-amber-500" />
        <label for="calc-glass" class="font-semibold text-gray-700" data-i18n="withGlassLabel">¿Con cristal?</label>
      </div>

      <!-- Glass type -->
      <div id="glass-type-wrapper">
        <label for="calc-glass-type" class="block font-semibold mb-1 text-gray-700" data-i18n="glassTypeLabel">Tipo de cristal</label>
        <select
          id="calc-glass-type"
          name="glassType"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none"
        >
          {GLASS_TYPES.map((g) => (
            <option value={g.id} data-price={g.pricePerM2} data-label-es={g.labelES} data-label-de={g.labelDE} data-label-en={g.labelEN}>
              {g.labelES} — €{g.pricePerM2.toFixed(2)}/m²
            </option>
          ))}
        </select>
      </div>

      <!-- With backing -->
      <div class="flex items-center gap-3">
        <input type="checkbox" id="calc-backing" name="withBacking" checked class="w-5 h-5 text-amber-600 rounded focus:ring-amber-500" />
        <label for="calc-backing" class="font-semibold text-gray-700" data-i18n="withBackingLabel">¿Con trasera de cartón?</label>
      </div>

      <!-- Calculate button -->
      <button
        type="submit"
        class="w-full bg-amber-700 text-white font-bold py-3 rounded-lg hover:bg-amber-800 transition-colors text-lg"
        data-i18n="calculateButton"
      >
        Calcular
      </button>
    </form>

    <!-- Results -->
    <div id="calc-results" class="hidden mt-8 bg-amber-50 p-6 rounded-xl border border-amber-200 space-y-3">
      <div class="flex justify-between">
        <span data-i18n="frameCostLabel">Coste del marco</span>
        <span id="result-frame" class="font-bold">€0.00</span>
      </div>
      <div id="result-glass-row" class="flex justify-between">
        <span data-i18n="glassCostLabel">Coste del cristal</span>
        <span id="result-glass" class="font-bold">€0.00</span>
      </div>
      <hr class="border-amber-300" />
      <div class="flex justify-between text-xl">
        <span class="font-bold" data-i18n="totalLabel">Total estimado</span>
        <span id="result-total" class="font-bold text-amber-800">€0.00</span>
      </div>
      <a
        id="whatsapp-btn"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 block text-center bg-green-600 text-white font-bold py-3 rounded-lg hover:bg-green-700 transition-colors text-lg"
        aria-label="Order via WhatsApp"
      >
        <span data-i18n="orderWhatsApp">Pedir por WhatsApp</span>
      </a>
    </div>
  </div>
</section>

<script>
  import { translations } from '../i18n/translations';
  import type { Lang } from '../i18n/translations';

  function getLang(): Lang {
    const html = document.documentElement.lang;
    if (html === 'de' || html === 'en') return html;
    return 'es';
  }

  const form = document.getElementById('calc-form') as HTMLFormElement;
  const glassCheck = document.getElementById('calc-glass') as HTMLInputElement;
  const backingCheck = document.getElementById('calc-backing') as HTMLInputElement;
  const glassWrapper = document.getElementById('glass-type-wrapper') as HTMLDivElement;
  const resultsDiv = document.getElementById('calc-results') as HTMLDivElement;

  glassCheck.addEventListener('change', () => {
    glassWrapper.style.display = glassCheck.checked ? '' : 'none';
    backingCheck.disabled = !glassCheck.checked;
    if (!glassCheck.checked) backingCheck.checked = false;
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const lang = getLang();
    const t = translations[lang];

    const width = parseFloat((document.getElementById('calc-width') as HTMLInputElement).value);
    const height = parseFloat((document.getElementById('calc-height') as HTMLInputElement).value);
    const frameSelect = document.getElementById('calc-frame') as HTMLSelectElement;
    const glassSelect = document.getElementById('calc-glass-type') as HTMLSelectElement;
    const withGlass = glassCheck.checked;

    const frameOption = frameSelect.selectedOptions[0];
    const framePricePerMeter = parseFloat(frameOption.dataset.price!);
    const actualFrameLabel = frameOption.getAttribute(`data-label-${lang}`) || frameOption.textContent || '';

    const frameMeters = 2 * (width + height) / 100;
    const frameCost = frameMeters * framePricePerMeter;
    const areaM2 = (width * height) / 10000;

    let glassCost = 0;
    let glassLabel: string = t.noGlass;
    if (withGlass) {
      const glassOption = glassSelect.selectedOptions[0];
      const glassPricePerM2 = parseFloat(glassOption.dataset.price!);
      glassCost = areaM2 * glassPricePerM2;
      glassLabel = glassOption.getAttribute(`data-label-${lang}`) || glassOption.textContent || '';
    }

    const total = Math.round((frameCost + glassCost) * 100) / 100;

    document.getElementById('result-frame')!.textContent = `€${frameCost.toFixed(2)}`;
    document.getElementById('result-glass')!.textContent = `€${glassCost.toFixed(2)}`;
    document.getElementById('result-total')!.textContent = `€${total.toFixed(2)}`;

    const glassRow = document.getElementById('result-glass-row') as HTMLDivElement;
    glassRow.style.display = withGlass ? '' : 'none';

    resultsDiv.classList.remove('hidden');

    // WhatsApp link
    const msg = t.whatsappMessage
      .replace('{width}', String(width))
      .replace('{height}', String(height))
      .replace('{frameLabel}', actualFrameLabel)
      .replace('{glassLabel}', glassLabel)
      .replace('{total}', total.toFixed(2));

    const waUrl = `https://wa.me/34647082690?text=${encodeURIComponent(msg)}`;
    (document.getElementById('whatsapp-btn') as HTMLAnchorElement).href = waUrl;
  });
</script>
