---
const CARD_COUNT = 6;
---
<section id="gallery" class="py-24 md:py-32 px-4 bg-brand-dark-alt">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-4 text-brand-ivory" data-i18n="galleryTitle">Galería</h2>
    <div class="w-16 h-px bg-brand-gold mx-auto mb-16"></div>

    <div class="relative">
      <!-- Prev button -->
      <button id="gallery-prev" aria-label="Previous" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 md:-translate-x-6 z-10 w-10 h-10 flex items-center justify-center rounded-full border border-brand-gold/60 bg-brand-dark/90 text-brand-gold hover:bg-brand-gold hover:text-brand-dark transition-all cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <!-- Carousel track -->
      <div id="gallery-track" class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory px-2 pb-4" style="scrollbar-width: none; -ms-overflow-style: none;">
        {Array.from({ length: CARD_COUNT }).map((_, i) => (
          <div class="gallery-card flex-shrink-0 w-[calc(100%-1rem)] sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] snap-start aspect-[4/3] rounded-lg flex flex-col items-center justify-center border-2 border-dashed border-brand-gold/40 bg-brand-dark/50" data-index={i}>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-brand-gold/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="1" />
              <rect x="5.5" y="5.5" width="13" height="13" rx="0.5" />
              <line x1="3" y1="3" x2="5.5" y2="5.5" />
              <line x1="21" y1="3" x2="18.5" y2="5.5" />
              <line x1="3" y1="21" x2="5.5" y2="18.5" />
              <line x1="21" y1="21" x2="18.5" y2="18.5" />
            </svg>
            <p class="text-brand-ivory-muted text-sm italic font-heading" data-i18n="photoComingSoon">Foto próximamente</p>
          </div>
        ))}
      </div>

      <!-- Next button -->
      <button id="gallery-next" aria-label="Next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 md:translate-x-6 z-10 w-10 h-10 flex items-center justify-center rounded-full border border-brand-gold/60 bg-brand-dark/90 text-brand-gold hover:bg-brand-gold hover:text-brand-dark transition-all cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <!-- Dots indicator -->
    <div id="gallery-dots" class="flex justify-center gap-2 mt-6">
      {Array.from({ length: CARD_COUNT }).map((_, i) => (
        <button class="gallery-dot w-2 h-2 rounded-full bg-brand-gold/30 transition-all cursor-pointer border-none p-0" data-dot={i} aria-label={`Go to slide ${i + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<style>
  #gallery-track::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const track = document.getElementById('gallery-track')!;
  const prevBtn = document.getElementById('gallery-prev')!;
  const nextBtn = document.getElementById('gallery-next')!;
  const dots = document.querySelectorAll('.gallery-dot');
  const cards = document.querySelectorAll('.gallery-card');

  function getVisibleCount() {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 640) return 2;
    return 1;
  }

  function getCardWidth() {
    const card = cards[0] as HTMLElement;
    if (!card) return 0;
    return card.offsetWidth + 24; // 24px = gap-6
  }

  function getCurrentIndex() {
    const cardW = getCardWidth();
    if (cardW === 0) return 0;
    return Math.round(track.scrollLeft / cardW);
  }

  function scrollToIndex(idx: number) {
    const maxIdx = cards.length - getVisibleCount();
    const clamped = Math.max(0, Math.min(idx, maxIdx));
    track.scrollTo({ left: clamped * getCardWidth(), behavior: 'smooth' });
  }

  function updateDots() {
    const idx = getCurrentIndex();
    dots.forEach((dot, i) => {
      if (i === idx) {
        dot.classList.add('bg-brand-gold');
        dot.classList.remove('bg-brand-gold/30');
      } else {
        dot.classList.remove('bg-brand-gold');
        dot.classList.add('bg-brand-gold/30');
      }
    });
  }

  prevBtn.addEventListener('click', () => scrollToIndex(getCurrentIndex() - 1));
  nextBtn.addEventListener('click', () => scrollToIndex(getCurrentIndex() + 1));

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => scrollToIndex(i));
  });

  track.addEventListener('scroll', updateDots);
  updateDots();
</script>
