---
---
<section id="gallery" class="py-24 md:py-32 px-4 bg-brand-dark-alt">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-4 text-brand-ivory" data-i18n="galleryTitle">Galería</h2>
    <div class="w-16 h-px bg-brand-gold mx-auto mb-16"></div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {Array.from({ length: 6 }).map(() => (
        <div class="aspect-[4/3] rounded-lg flex flex-col items-center justify-center border-2 border-dashed border-brand-gold/40 bg-brand-dark/50">
          {/* Frame icon SVG placeholder */}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-brand-gold/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="1" />
            <rect x="5.5" y="5.5" width="13" height="13" rx="0.5" />
            <line x1="3" y1="3" x2="5.5" y2="5.5" />
            <line x1="21" y1="3" x2="18.5" y2="5.5" />
            <line x1="3" y1="21" x2="5.5" y2="18.5" />
            <line x1="21" y1="21" x2="18.5" y2="18.5" />
          </svg>
          <p class="text-brand-ivory-muted text-sm italic font-heading" data-i18n="photoComingSoon">Foto próximamente</p>
        </div>
      ))}
    </div>
  </div>
</section>
