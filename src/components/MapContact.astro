---
import businessCard from '../assets/raw/business-card-es.jpg';
---
<section id="contact" class="py-16 px-4 bg-gray-50">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-10 text-amber-900" data-i18n="mapTitle">Cómo encontrarnos</h2>

    <div class="grid md:grid-cols-2 gap-8 items-center">
      <!-- Map image from business card -->
      <div class="rounded-xl overflow-hidden shadow-lg">
        <img
          src={businessCard.src}
          alt="Mapa de ubicación de Enmarcaciones El Peñón en Puerto de la Cruz, Tenerife"
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </div>

      <!-- Contact info -->
      <div class="space-y-6">
        <div>
          <h3 class="font-bold text-xl text-amber-900 mb-2">Enmarcaciones El Peñón</h3>
          <p class="text-gray-700" data-i18n="address">Transversal C/ Mequínez, 138, Puerto de la Cruz, Tenerife</p>
        </div>

        <a
          href="tel:+34647082690"
          class="inline-flex items-center gap-2 text-lg font-semibold text-amber-800 hover:text-amber-600 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          647 08 26 90
        </a>

        <a
          href="https://maps.google.com/?q=Enmarcaciones+El+Peñon+Puerto+de+la+Cruz+Tenerife"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-amber-700 text-white font-bold px-6 py-3 rounded-lg hover:bg-amber-800 transition-colors"
          data-i18n="getDirections"
        >
          Cómo llegar
        </a>
      </div>
    </div>
  </div>
</section>
